# ------------------------------------------------------------
# Melos / Monorepo Specific
# ------------------------------------------------------------
.melos_tool/
melos_logs/
# Ignore pubspec.lock in shared packages (libraries), but keep them for apps
packages/**/pubspec.lock

# ------------------------------------------------------------
# Global System & IDE Files (Recursive)
# ------------------------------------------------------------
# These patterns use **/ to ensure they are ignored in every sub-folder
**/.DS_Store
**/.history
**/.svn/
**/.atom/
**/.idea/
**/.vscode/
**/*.iml
**/*.ipr
**/*.iws
**/*.swp
**/*.class
**/*.log
**/*.pyc
**/migrate_working_dir/

# ------------------------------------------------------------
# Global Flutter/Dart Build Artifacts (Recursive)
# ------------------------------------------------------------
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/doc/api/
**/coverage/

# ------------------------------------------------------------
# Global Mobile Artifacts (Recursive Safety)
# ------------------------------------------------------------
**/android/.gradle
**/android/captures/
**/android/**/*.jks
**/android/local.properties
**/android/key.properties
**/ios/.generated/
**/ios/Pods/
**/ios/Podfile.lock