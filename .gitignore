# ------------------------------------------------------------
# Melos / Monorepo Specific
# ------------------------------------------------------------
.melos_tool/
melos_logs/
**/pubspec_overrides.yaml

# Ignore pubspec.lock in shared packages (libraries), but keep them for apps
packages/**/pubspec.lock

# ------------------------------------------------------------
# Global System & IDE Files (Recursive)
# ------------------------------------------------------------
# These patterns use **/ to ensure they are ignored in every sub-folder
**/.DS_Store
**/.history
**/.svn/
**/.atom/
**/.idea/
**/.vscode/
**/*.iml
**/*.ipr
**/*.iws
**/*.swp
**/*.class
**/*.log
**/*.pyc
**/migrate_working_dir/
**/google-services.json

# ------------------------------------------------------------
# Global Flutter/Dart Build Artifacts (Recursive)
# ------------------------------------------------------------
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/doc/api/
**/coverage/

# ------------------------------------------------------------
# Global Mobile Artifacts (Recursive Safety)
# ------------------------------------------------------------
**/android/.gradle
**/android/captures/
**/android/**/*.jks
**/android/local.properties
**/android/key.properties
**/ios/.generated/
**/ios/Pods/
/apps/admin/linux/flutter/generated_plugin_registrant.cc
/apps/admin/windows/flutter/generated_plugin_registrant.cc
/apps/seller/linux/flutter/generated_plugin_registrant.cc
/apps/seller/windows/flutter/generated_plugin_registrant.cc
/apps/admin/linux/flutter/generated_plugin_registrant.h
/apps/admin/windows/flutter/generated_plugin_registrant.h
/apps/seller/linux/flutter/generated_plugin_registrant.h
/apps/seller/windows/flutter/generated_plugin_registrant.h
/apps/admin/linux/flutter/generated_plugins.cmake
/apps/admin/windows/flutter/generated_plugins.cmake
/apps/seller/linux/flutter/generated_plugins.cmake
/apps/seller/windows/flutter/generated_plugins.cmake
/apps/admin/macos/Flutter/GeneratedPluginRegistrant.swift
/apps/seller/macos/Flutter/GeneratedPluginRegistrant.swift
/apps/admin/pubspec.lock
/apps/customer/pubspec.lock
/apps/seller/pubspec.lock
